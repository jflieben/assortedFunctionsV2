{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the storage account."
      }
    },
    "applyTagsToResourceGroup": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When true, apply tags to the main resource group."
      }
    },
    "applyTagsToAllResources": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "When true, apply tags to deployed resources."
      }
    },
    "customTags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Tags payload from the wizard's TagsByResource control."
      }
    },
    "selectedSubscriptionIdsRaw": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Either a single subscription ID, or a JSON array string (e.g. [\"id1\",\"id2\"]) of subscription IDs to receive Reader + Cost Management Reader. Empty = none."
      }
    }
  },
  "variables": {
    "spnObjectId": "4bc18533-99fb-401d-9ef1-b9e03b4ca51b",
    "blobRoleId": "ba92f5b4-2d11-453d-a403-e96b0029c9fe",
    "tableRoleId": "0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3",
    "readerRoleId": "acdd72a7-3385-48ef-bd42-f606fba81ae7",
    "costReaderRoleId": "72fafb9e-0641-4937-9268-a91bfd8191a3",
    "storageAccountName": "[toLower(take(concat('ccs', uniqueString(resourceGroup().id, variables('spnObjectId'))), 24))]",
    "selectedSubscriptionIds": "[if(empty(parameters('selectedSubscriptionIdsRaw')), createArray(), if(startsWith(parameters('selectedSubscriptionIdsRaw'), '['), json(parameters('selectedSubscriptionIdsRaw')), createArray(parameters('selectedSubscriptionIdsRaw'))))]"
  },
  "resources": [
    {
      "condition": "[and(parameters('applyTagsToResourceGroup'), contains(parameters('customTags'), 'Microsoft.Resources/resourceGroups'))]",
      "type": "Microsoft.Resources/tags",
      "apiVersion": "2021-04-01",
      "name": "default",
      "scope": "[format('subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, resourceGroup().name)]",
      "properties": {
        "tags": "[parameters('customTags')['Microsoft.Resources/resourceGroups']]"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "tags": "[if(and(parameters('applyTagsToAllResources'), contains(parameters('customTags'), 'Microsoft.Storage/storageAccounts')), parameters('customTags')['Microsoft.Storage/storageAccounts'], json('{}'))]",
      "properties": {
        "accessTier": "Hot",
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true,
        "allowSharedKeyAccess": false,
        "publicNetworkAccess": "Enabled",
        "allowBlobPublicAccess": true,
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices",
          "ipRules": [],
          "virtualNetworkRules": []
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), variables('spnObjectId'), variables('blobRoleId'))]",
      "scope": "[concat('Microsoft.Storage/storageAccounts/', variables('storageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": {
        "principalId": "[variables('spnObjectId')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('blobRoleId'))]"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), variables('spnObjectId'), variables('tableRoleId'))]",
      "scope": "[concat('Microsoft.Storage/storageAccounts/', variables('storageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": {
        "principalId": "[variables('spnObjectId')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('tableRoleId'))]"
      }
    },
    {
      "condition": "[greater(length(variables('selectedSubscriptionIds')), 0)]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "[concat('ccs-sub-roles-', variables('selectedSubscriptionIds')[copyIndex()])]",
      "location": "[parameters('location')]",
      "subscriptionId": "[variables('selectedSubscriptionIds')[copyIndex()]]",
      "copy": {
        "name": "subRoleAssignments",
        "count": "[if(equals(length(variables('selectedSubscriptionIds')), 0), 1, length(variables('selectedSubscriptionIds')))]"
      },
      "properties": {
        "mode": "Incremental",
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "variables": {
            "spnObjectId": "4bc18533-99fb-401d-9ef1-b9e03b4ca51b",
            "readerRoleId": "acdd72a7-3385-48ef-bd42-f606fba81ae7",
            "costReaderRoleId": "72fafb9e-0641-4937-9268-a91bfd8191a3"
          },
          "resources": [
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(subscription().subscriptionId, variables('spnObjectId'), variables('readerRoleId'))]",
              "properties": {
                "principalId": "[variables('spnObjectId')]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('readerRoleId'))]"
              }
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "name": "[guid(subscription().subscriptionId, variables('spnObjectId'), variables('costReaderRoleId'))]",
              "properties": {
                "principalId": "[variables('spnObjectId')]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('costReaderRoleId'))]"
              }
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    }
  }
}
