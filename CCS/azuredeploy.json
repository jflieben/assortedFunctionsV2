{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "storageAccountNamePrefix": {
      "type": "string",
      "defaultValue": "ccs",
      "metadata": {
        "description": "Prefix used to auto-generate a globally unique storage account name."
      },
      "minLength": 3,
      "maxLength": 11
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the storage account."
      }
    },
    "selectedSubscriptionIds": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Subscription IDs that should receive Reader and Cost Management Reader role assignments for the same SPN.",
        "strongType": "subscription"
      }
    }
  },
  "variables": {
    "spnObjectId": "4bc18533-99fb-401d-9ef1-b9e03b4ca51b",
    "generatedStorageAccountName": "[toLower(take(concat(parameters('storageAccountNamePrefix'), uniqueString(resourceGroup().id, variables('spnObjectId'))), 24))]",
    "blobDataContributorRoleDefinitionId": "ba92f5b4-2d11-453d-a403-e96b0029c9fe",
    "tableDataContributorRoleDefinitionId": "0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3",
    "readerRoleDefinitionId": "acdd72a7-3385-48ef-bd42-f606fba81ae7",
    "costManagementReaderRoleDefinitionId": "72fafb9e-0641-4937-9268-a91bfd8191a3"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('generatedStorageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "accessTier": "Hot",
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true,
        "publicNetworkAccess": "Enabled",
        "allowBlobPublicAccess": true,
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices",
          "ipRules": [],
          "virtualNetworkRules": []
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('generatedStorageAccountName')), variables('spnObjectId'), variables('blobDataContributorRoleDefinitionId'))]",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('generatedStorageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('generatedStorageAccountName'))]"
      ],
      "properties": {
        "principalId": "[variables('spnObjectId')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('blobDataContributorRoleDefinitionId'))]"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('generatedStorageAccountName')), variables('spnObjectId'), variables('tableDataContributorRoleDefinitionId'))]",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', variables('generatedStorageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('generatedStorageAccountName'))]"
      ],
      "properties": {
        "principalId": "[variables('spnObjectId')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('tableDataContributorRoleDefinitionId'))]"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(format('/subscriptions/{0}', parameters('selectedSubscriptionIds')[copyIndex('readerAssignments')]), variables('spnObjectId'), variables('readerRoleDefinitionId'))]",
      "scope": "[format('/subscriptions/{0}', parameters('selectedSubscriptionIds')[copyIndex('readerAssignments')])]",
      "copy": {
        "name": "readerAssignments",
        "count": "[length(parameters('selectedSubscriptionIds'))]"
      },
      "properties": {
        "principalId": "[variables('spnObjectId')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId(parameters('selectedSubscriptionIds')[copyIndex('readerAssignments')], 'Microsoft.Authorization/roleDefinitions', variables('readerRoleDefinitionId'))]"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(format('/subscriptions/{0}', parameters('selectedSubscriptionIds')[copyIndex('costReaderAssignments')]), variables('spnObjectId'), variables('costManagementReaderRoleDefinitionId'))]",
      "scope": "[format('/subscriptions/{0}', parameters('selectedSubscriptionIds')[copyIndex('costReaderAssignments')])]",
      "copy": {
        "name": "costReaderAssignments",
        "count": "[length(parameters('selectedSubscriptionIds'))]"
      },
      "properties": {
        "principalId": "[variables('spnObjectId')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId(parameters('selectedSubscriptionIds')[copyIndex('costReaderAssignments')], 'Microsoft.Authorization/roleDefinitions', variables('costManagementReaderRoleDefinitionId'))]"
      }
    }
  ],
  "outputs": {
    "storageAccountName": {
      "type": "string",
      "value": "[variables('generatedStorageAccountName')]"
    },
    "storageAccountResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Storage/storageAccounts', variables('generatedStorageAccountName'))]"
    }
  }
}