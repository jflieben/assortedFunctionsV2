{
  "$schema": "https://schema.management.azure.com/schemas/2021-09-09/uiFormDefinition.schema.json#",
  "view": {
    "kind": "Form",
    "properties": {
      "title": "CCS Storage + RBAC Deployment",
      "steps": [
        {
          "name": "basics",
          "label": "Basics",
          "elements": [
            {
              "name": "resourceScope",
              "type": "Microsoft.Common.ResourceScope",
              "location": {
                "resourceTypes": [
                  "microsoft.resources/resourcegroups"
                ]
              }
            }
          ]
        },
        {
          "name": "deploymentSettings",
          "label": "Deployment settings",
          "elements": [
            {
              "name": "storageAccountNamePrefix",
              "type": "Microsoft.Common.TextBox",
              "label": "Storage Account Name Prefix",
              "defaultValue": "ccs",
              "toolTip": "3-11 lowercase letters/numbers. Final account name is autogenerated.",
              "constraints": {
                "required": true,
                "regex": "^[a-z0-9]{3,11}$",
                "validationMessage": "Use 3-11 lowercase letters/numbers."
              }
            },
            {
              "name": "subscriptionsApi",
              "type": "Microsoft.Solutions.ArmApiControl",
              "request": {
                "method": "GET",
                "path": "subscriptions?api-version=2020-01-01"
              }
            },
            {
              "name": "selectedSubscriptionIds",
              "type": "Microsoft.Common.DropDown",
              "label": "Subscriptions for Reader + Cost Management Reader",
              "toolTip": "Select one or more subscriptions where this SPN should get Reader and Cost Management Reader.",
              "multiselect": true,
              "selectAll": true,
              "filter": true,
              "constraints": {
                "required": true,
                "allowedValues": "[map(steps('deploymentSettings').subscriptionsApi.value, (item) => parse(concat('{\"label\":\"', item.displayName, ' (', item.subscriptionId, ')\",\"value\":\"', item.subscriptionId, '\"}')))]"
              }
            }
          ]
        }
      ]
    },
    "outputs": {
      "kind": "ResourceGroup",
      "location": "[steps('basics').resourceScope.location.name]",
      "resourceGroupId": "[steps('basics').resourceScope.resourceGroup.id]",
      "parameters": {
        "location": "[steps('basics').resourceScope.location.name]",
        "storageAccountNamePrefix": "[steps('deploymentSettings').storageAccountNamePrefix]",
        "selectedSubscriptionIds": "[steps('deploymentSettings').selectedSubscriptionIds]"
      }
    }
  }
}