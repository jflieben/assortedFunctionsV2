{
  "$schema": "https://schema.management.azure.com/schemas/2021-09-09/uiFormDefinition.schema.json#",
  "view": {
    "kind": "Form",
    "properties": {
      "title": "CCS Storage + RBAC Deployment",
      "steps": [
        {
          "name": "storage",
          "label": "Storage account",
          "elements": [
            {
              "name": "subscriptionsApi",
              "type": "Microsoft.Solutions.ArmApiControl",
              "request": {
                "method": "GET",
                "path": "subscriptions?api-version=2020-01-01"
              }
            },
            {
              "name": "storageSubscriptionId",
              "type": "Microsoft.Common.DropDown",
              "label": "Subscription for storage account",
              "toolTip": "Select the subscription where the storage account + resource group will be deployed.",
              "filter": true,
              "constraints": {
                "required": true,
                "allowedValues": "[map(steps('storage').subscriptionsApi.value, (item) => parse(concat('{\"label\":\"', item.displayName, ' (', item.subscriptionId, ')\",\"value\":\"', item.subscriptionId, '\"}')))]"
              }
            },
            {
              "name": "location",
              "type": "Microsoft.Common.DropDown",
              "label": "Region",
              "defaultValue": "West Europe",
              "toolTip": "Azure region for the storage account.",
              "constraints": {
                "required": true,
                "allowedValues": [
                  { "label": "West Europe", "value": "westeurope" },
                  { "label": "North Europe", "value": "northeurope" },
                  { "label": "East US", "value": "eastus" },
                  { "label": "East US 2", "value": "eastus2" },
                  { "label": "West US 2", "value": "westus2" },
                  { "label": "West US 3", "value": "westus3" },
                  { "label": "Central US", "value": "centralus" },
                  { "label": "UK South", "value": "uksouth" },
                  { "label": "France Central", "value": "francecentral" },
                  { "label": "Germany West Central", "value": "germanywestcentral" },
                  { "label": "Sweden Central", "value": "swedencentral" },
                  { "label": "Switzerland North", "value": "switzerlandnorth" },
                  { "label": "Australia East", "value": "australiaeast" },
                  { "label": "Japan East", "value": "japaneast" },
                  { "label": "Southeast Asia", "value": "southeastasia" }
                ]
              }
            },
            {
              "name": "storageResourceGroupName",
              "type": "Microsoft.Common.TextBox",
              "label": "Resource group name (created if missing)",
              "defaultValue": "rg-ccs",
              "toolTip": "Name of the resource group to create or reuse.",
              "constraints": {
                "required": true,
                "regex": "^[a-zA-Z0-9._()-]{1,90}$",
                "validationMessage": "1-90 chars, letters/digits/._()- only."
              }
            },
            {
              "name": "storageAccountNamePrefix",
              "type": "Microsoft.Common.TextBox",
              "label": "Storage account name prefix",
              "defaultValue": "ccs",
              "toolTip": "3-11 lowercase letters/numbers. Final account name is autogenerated.",
              "constraints": {
                "required": true,
                "regex": "^[a-z0-9]{3,11}$",
                "validationMessage": "Use 3-11 lowercase letters/numbers."
              }
            }
          ]
        },
        {
          "name": "permissions",
          "label": "Permissions scope",
          "elements": [
            {
              "name": "infoBox",
              "type": "Microsoft.Common.InfoBox",
              "visible": true,
              "options": {
                "icon": "Info",
                "text": "The SPN always gets Storage Blob/Table Data Contributor on the new storage account. Choose below where it also gets Reader + Cost Management Reader."
              }
            },
            {
              "name": "monitorAll",
              "type": "Microsoft.Common.CheckBox",
              "label": "Monitor all Azure subscriptions",
              "toolTip": "If checked, Reader + Cost Management Reader are assigned at the tenant root management group (inherited by all current and future subscriptions). Requires User Access Administrator at root.",
              "constraints": {
                "required": false
              }
            },
            {
              "name": "selectedSubscriptionIds",
              "type": "Microsoft.Common.DropDown",
              "label": "Subscriptions to monitor",
              "toolTip": "Select subscriptions where the SPN should get Reader + Cost Management Reader.",
              "multiselect": true,
              "selectAll": true,
              "filter": true,
              "visible": "[not(equals(steps('permissions').monitorAll, true))]",
              "constraints": {
                "required": "[not(equals(steps('permissions').monitorAll, true))]",
                "allowedValues": "[map(steps('storage').subscriptionsApi.value, (item) => parse(concat('{\"label\":\"', item.displayName, ' (', item.subscriptionId, ')\",\"value\":\"', item.subscriptionId, '\"}')))]"
              }
            }
          ]
        }
      ]
    },
    "outputs": {
      "kind": "Tenant",
      "location": "[steps('storage').location]",
      "parameters": {
        "storageSubscriptionId": "[steps('storage').storageSubscriptionId]",
        "storageResourceGroupName": "[steps('storage').storageResourceGroupName]",
        "storageAccountNamePrefix": "[steps('storage').storageAccountNamePrefix]",
        "location": "[steps('storage').location]",
        "monitorAllSubscriptions": "[steps('permissions').monitorAll]",
        "selectedSubscriptionIds": "[if(equals(steps('permissions').monitorAll, true), parse('[]'), steps('permissions').selectedSubscriptionIds)]"
      }
    }
  }
}